# Copy to .env.local and fill in. Never commit real secrets — .env.local is gitignored.

# --- Database (Neon Postgres) -------------------------------------------------
# Create a project at https://neon.tech (or via the Vercel Marketplace) and paste
# the pooled connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js ------------------------------------------------------------------
# Secret used to encrypt session data. Generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth credentials.
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
# Authorized redirect URI (local):
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
