# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay local; the template is committed for documentation
.env*
!.env.example

# vercel
.vercel

# design notes — running history of architecture/design conversations; kept local for
# now, but the convention (README) is shared
/design-notes/*
!/design-notes/README.md

# playwright (e2e) — generated artifacts
/test-results
/playwright-report
/blob-report
/playwright/.cache

# typescript
*.tsbuildinfo
next-env.d.ts
