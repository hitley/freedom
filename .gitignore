# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay local; the template is committed for documentation
.env*
!.env.example

# vercel
.vercel

# playwright (e2e) — generated artifacts
/test-results
/playwright-report
/blob-report
/playwright/.cache

# vitepress build output + cache (the generated Markdown under docs/features IS
# committed — it's the staleness-checked artifact; only the built site is ignored)
/public/docs
/docs/.vitepress/cache
/docs/.vitepress/dist

# typescript
*.tsbuildinfo
next-env.d.ts
